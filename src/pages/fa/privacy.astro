---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | Hamdam"
  description="How Hamdam handles data: what it accesses, what it never collects, and how iCloud sync works."
  lang="fa"
  path="/fa/privacy"
  altPath="/privacy"
>
  <div class="mx-auto max-w-[var(--container-reading)] px-6 pb-32 pt-24 sm:pt-[100px]" lang="en" dir="ltr">
    <div class="mb-10 rounded-[var(--radius-card)] bg-peach/25 px-5 py-4 text-sm text-indigo/80">
      This page will contain the Persian translation of Hamdam's Privacy Policy. Native-speaker
      review is scheduled for the next content pass. The English version is available at
      <a href="/privacy" class="text-saffron-ink underline">/privacy</a>.
    </div>

    <h1 class="font-serif text-5xl font-bold text-indigo sm:text-[56px]">Privacy Policy</h1>

    <p class="mt-6 font-serif text-lg text-indigo/90">
      Read the full Privacy Policy in English:
      <a href="/privacy" class="text-saffron-ink underline">hamdam.com.au/privacy</a>
    </p>
  </div>
</BaseLayout>
