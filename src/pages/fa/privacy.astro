---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalSection from '../../components/LegalSection.astro';

const effectiveDate = 'پیش‌نویس — تاریخ اجرا پیش از عرضه‌ی نسخه‌ی 1.0 مشخص خواهد شد.';
---

<BaseLayout
  title="سیاست حریم خصوصی — همدم"
  description="همدم چگونه با داده‌ها رفتار می‌کند: به چه چیزی دسترسی دارد، چه چیزی را هرگز جمع‌آوری نمی‌کند، و همگام‌سازی iCloud چگونه کار می‌کند."
  lang="fa"
  path="/fa/privacy"
  altPath="/privacy"
>
  <div class="mx-auto max-w-[var(--container-reading)] px-6 pb-32 pt-24 sm:pt-[100px]">
    <div class="mb-10 rounded-[var(--radius-card)] bg-peach/25 px-5 py-4 font-farsi text-sm text-indigo/80">
      ⚠️ سند پیش‌نویس. محتوا پیش از عرضه‌ی نسخه‌ی 1.0 نهایی می‌شود.
    </div>

    <h1 class="font-farsi text-4xl font-bold text-indigo sm:text-5xl">سیاست حریم خصوصی</h1>
    <p class="mt-3 font-farsi text-sm text-indigo/60">{effectiveDate}</p>

    <LegalSection heading="۱. مقدمه" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای «مقدمه»ی سیاست حریم
        خصوصی همدم است.]
      </p>
    </LegalSection>

    <LegalSection heading="۲. همدم به چه داده‌هایی دسترسی دارد" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «داده‌هایی که همدم
        به آن‌ها دسترسی دارد» است و HealthKit، EventKit، WeatherKit، موقعیت مکانی و iCloud را در
        بر می‌گیرد.]
      </p>
    </LegalSection>

    <LegalSection heading="۳. کارهایی که همدم انجام نمی‌دهد" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «کارهایی که همدم
        انجام نمی‌دهد» است: بدون حساب کاربری، بدون آمار کاربری، بدون تبلیغات، و بدون فروش داده.]
      </p>
    </LegalSection>

    <LegalSection heading="۴. همگام‌سازی iCloud" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «همگام‌سازی iCloud»
        است. همگام‌سازی فقط از طریق حساب iCloud خود کاربر انجام می‌شود، نه سرورهای همدم.]
      </p>
    </LegalSection>

    <LegalSection heading="۵. نقش اپل" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «نقش اپل» است که
        خدمات پلتفرم ارائه‌شده توسط اپل را پوشش می‌دهد.]
      </p>
    </LegalSection>

    <LegalSection heading="۶. iTunes Search API" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «iTunes Search API»
        است که به‌روزرسانی هفتگی بخش کشف را پوشش می‌دهد.]
      </p>
    </LegalSection>

    <LegalSection heading="۷. حذف حساب کاربری" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «حذف حساب کاربری»
        است که فرایند حذف درون‌برنامه‌ای را پوشش می‌دهد.]
      </p>
    </LegalSection>

    <LegalSection heading="۸. منبع اشعار فارسی" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «منبع اشعار فارسی»
        است که منبع Ganjoor.net را پوشش می‌دهد.]
      </p>
    </LegalSection>

    <LegalSection heading="۹. کودکان" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «کودکان» است. همدم
        برای کودکان زیر 13 سال طراحی نشده است.]
      </p>
    </LegalSection>

    <LegalSection heading="۱۰. تغییرات این سیاست" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «تغییرات این سیاست»
        است که نحوه‌ی اطلاع‌رسانی به‌روزرسانی‌ها را پوشش می‌دهد.]
      </p>
    </LegalSection>

    <LegalSection heading="۱۱. تماس با ما" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «تماس با ما» است.]
        برای تماس:
        <a href="mailto:hello@hamdam.com.au" class="text-saffron-ink underline">hello@hamdam.com.au</a>.
      </p>
    </LegalSection>

    <LegalSection heading="۱۲. قانون حاکم" lang="fa">
      <p>
        [محتوای کامل در انتظار نگارش نهایی است — این بخش جای‌نگه‌دار برای بخش «قانون حاکم» است.
        این سیاست تابع قوانین ایالت کوئینزلند، استرالیا خواهد بود.]
      </p>
    </LegalSection>
  </div>
</BaseLayout>
