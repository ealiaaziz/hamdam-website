---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service | Hamdam"
  description="The terms governing use of the Hamdam app, subscription, and journal content."
  lang="fa"
  path="/fa/terms"
  altPath="/terms"
>
  <div class="mx-auto max-w-[var(--container-reading)] px-6 pb-32 pt-24 sm:pt-[100px]">
    <div class="mb-10 rounded-[var(--radius-card)] bg-peach/25 px-5 py-4 text-sm text-indigo/80" dir="ltr">
      This page will contain the Persian translation of Hamdam's Terms of Service. Native-speaker
      review is scheduled for the next content pass. The English version is available at
      <a href="/terms" class="text-saffron-ink underline">/terms</a>.
    </div>

    <h1 class="font-serif text-5xl font-bold text-indigo sm:text-[56px]" dir="ltr">Terms of Service</h1>

    <p class="mt-6 font-serif text-lg text-indigo/90" dir="ltr">
      Read the full Terms of Service in English:
      <a href="/terms" class="text-saffron-ink underline">hamdam.com.au/terms</a>
    </p>
  </div>
</BaseLayout>
