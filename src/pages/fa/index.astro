---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCinematic from '../../components/HeroCinematic.astro';
import MoodDemo from '../../components/MoodDemo.astro';
import VerseShowcase from '../../components/VerseShowcase.astro';
import { faCopy } from '../../data/siteCopy';
import PoetsBand from '../../components/PoetsBand.astro';
import ContextConstellation from '../../components/ContextConstellation.astro';
import JourneyPair from '../../components/JourneyPair.astro';
import RootsMoments from '../../components/RootsMoments.astro';
import PrivacyTrust from '../../components/PrivacyTrust.astro';
import PlansAndFoundingCompanion from '../../components/PlansAndFoundingCompanion.astro';
import FinalCeremony from '../../components/FinalCeremony.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import FeatureIcon from '../../components/FeatureIcon.astro';
import HamdamLogotype from '../../components/HamdamLogotype.astro';
import SceneBackground from '../../components/SceneBackground.astro';
import quietGarden from '../../assets/scenes/quiet-garden-section.jpg';
import dawn from '../../assets/scenes/dawn-section.jpg';
---

<BaseLayout
  title="همدم: همراهی برای تأمل روزانه، ریشه‌دار در خرد شعر فارسی"
  description="همدم، آینه‌ی قلب و آسمان توست. همراهی روزانه برای تأمل، ریشه‌دار در خرد شعر فارسی. اکنون برای آیفون در دسترس است."
  lang="fa"
  path="/fa/"
>
  <HeroCinematic lang="fa" title={faCopy.tagline} subhead={faCopy.subhead} />

  <MoodDemo lang="fa" />

  <!-- VERSE SHOWCASE -->
  <VerseShowcase lang="fa" intro={faCopy.verseIntro} sceneImage={dawn} />

  <SectionDivider />

  <!-- WHAT HAMDAM IS -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        همدمی برای تأمل روزانه.
      </h2>
      <div class="mt-8 space-y-6 font-farsi text-lg leading-[1.9] text-indigo/90">
        <p>
          همدم هر روز، در همان ساعتی که به سراغت می‌آید، همراهت می‌شود؛ صبحی که به‌آرامی باز
          می‌شود، عصری که آرام می‌کند، شبی که روز را به آرامش می‌رساند. حال دلت را با یک حرکت
          ساده بگو، همدم شعر و تأملی متناسب با آن حس برایت می‌آورد.
        </p>
        <p>
          هر شعر با متن اصلی پارسی در کنار برگردان انگلیسی می‌آید، از حافظ، مولانا، سعدی، خیام و
          پروین اعتصامی.
        </p>
        <p>
          روزشماری آرام همراهی می‌کند که یک روز از قلم‌افتاده را می‌بخشد. هر تأمل در یادداشتی
          خصوصی نگه داشته می‌شود که از صفحه‌ی اصلی گوشی قابل جست‌وجوست، و شعرهای محبوبت همیشه در
          دسترس‌اند.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- FIVE POETS -->
  <PoetsBand lang="fa" />

  <!-- CONTEXT CONSTELLATION -->
  <ContextConstellation lang="fa" />

  <!-- YOUR JOURNEY -->
  <JourneyPair lang="fa" />

  <SectionDivider />

  <!-- ROOTS AND REGION -->
  <RootsMoments lang="fa" />

  <SectionDivider />

  <!-- QUIET INTELLIGENCE -->
  <section class="relative bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <SceneBackground image={quietGarden} />
    <div data-reveal class="relative mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        همدم هر جا که نگاه کنی، همراه توست.
      </h2>
      <p class="mt-8 font-farsi text-lg leading-[1.9] text-indigo/90">
        از سیری بخواه تأملی را آغاز کند، شعر امروز را بشنود، یا روزشمارت را بررسی کند. ابزارکی به
        صفحه‌ی اصلی اضافه کن. اگر اپل واچ داری، شعر و روزشمارت همراهت سفر می‌کنند. اگر بخواهی، هر
        تأمل می‌تواند به‌عنوان یک ثبت حالت ذهنی در اپل هلث ذخیره شود، همراه با موسیقی آرام از اپل
        موزیک.
      </p>
    </div>
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap justify-center gap-x-10 gap-y-8">
      <FeatureIcon name="siri" label="سیری" lang="fa" />
      <FeatureIcon name="widget" label="ابزارک" lang="fa" />
      <FeatureIcon name="watch" label="اپل واچ" lang="fa" />
      <FeatureIcon name="health" label="اپل هلث" lang="fa" />
      <FeatureIcon name="music" label="اپل موزیک" lang="fa" />
    </div>
  </section>

  <SectionDivider />

  <!-- PRIVACY -->
  <PrivacyTrust lang="fa" />

  <!-- PLANS AND FOUNDING COMPANION -->
  <PlansAndFoundingCompanion lang="fa" />

  <!-- FINAL CEREMONY -->
  <FinalCeremony lang="fa" />

  <!-- FOOTER -->
  <footer class="border-t border-saffron/30 px-6 py-20">
    <div class="mx-auto flex max-w-xl flex-col items-center gap-4 text-center">
      <HamdamLogotype size={24} lang="fa" />
      <p class="font-farsi text-sm text-indigo/70">اپلیکیشنی از تیم همدم</p>
      <nav aria-label="Footer" class="flex items-center gap-3 font-farsi text-sm text-indigo/70">
        <a href="/fa/privacy" class="inline-flex min-h-[44px] items-center px-1 hover:text-indigo">حریم خصوصی</a>
        <span aria-hidden="true">·</span>
        <a href="/fa/terms" class="inline-flex min-h-[44px] items-center px-1 hover:text-indigo">شرایط استفاده</a>
        <span aria-hidden="true">·</span>
        <a href="mailto:developer@hamdam.com.au" class="inline-flex min-h-[44px] items-center px-1 hover:text-indigo">تماس با ما</a>
      </nav>
      <p class="font-farsi text-sm text-indigo/70">ساخته شده با عشق در بریزبن</p>
      <p class="font-farsi text-xs text-indigo/70">شعرها از گنجور گردآوری شده‌اند.</p>
    </div>
    <div class="mx-auto mt-10 flex max-w-xl flex-col items-center gap-2 border-t border-saffron/20 pt-8 text-center">
      <p class="text-xs text-indigo/70" lang="en" dir="ltr">&copy; {new Date().getFullYear()} Hamdam. All rights reserved.</p>
      <p class="text-xs text-indigo/70" lang="en" dir="ltr">
        HAMDAM&trade; is the subject of Australian trade mark application no. 2674427, filed 11
        July 2026.
      </p>
      {
        /* Plain text, not a second small link: تماس با ما above already
           points at this same address with a properly-sized 44px target
           (F7). */
      }
      <p class="text-xs text-indigo/70" lang="en" dir="ltr">
        For support, contact developer@hamdam.com.au.
      </p>
    </div>
  </footer>
</BaseLayout>
