---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PersianShamseh from '../../components/PersianShamseh.astro';
import AppStoreBadge from '../../components/AppStoreBadge.astro';
import VerseCard from '../../components/VerseCard.astro';
import PoetCard from '../../components/PoetCard.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import FeatureIcon from '../../components/FeatureIcon.astro';
import HamdamLogotype from '../../components/HamdamLogotype.astro';
import { poets } from '../../data/poets';
---

<BaseLayout
  title="همدم — همراهی برای تأمل روزانه، ریشه‌دار در خرد شعر فارسی"
  description="همدم، آینه‌ی قلب و آسمان توست. همراهی روزانه برای تأمل، ریشه‌دار در خرد شعر فارسی. به‌زودی برای آیفون."
  lang="fa"
  path="/fa/"
>
  <!-- HERO -->
  <section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 py-32 text-center">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-peach/40 via-peach/10 to-cream"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute left-1/2 top-[16%] -z-10 h-[560px] w-[560px] -translate-x-1/2 rounded-full bg-saffron/25 blur-[130px]"
      aria-hidden="true"
    ></div>

    <div class="mx-auto flex max-w-[800px] flex-col items-center">
      <PersianShamseh size={64} animated={true} />

      <h1 class="text-balance mt-10 font-farsi text-[40px] font-medium leading-[1.3] text-indigo sm:text-[60px] lg:text-[72px]">
        همدم، آینه‌ی قلب و آسمان توست.
      </h1>

      <p class="mt-8 max-w-xl font-farsi text-xl leading-[1.9] text-indigo/80 sm:text-2xl">
        همدمی برای تأمل روزانه، ریشه‌دار در خرد شعر فارسی.
      </p>

      <div class="mt-14">
        <AppStoreBadge lang="fa" />
      </div>
    </div>
  </section>

  <!-- VERSE SHOWCASE -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <VerseCard
      persian={`این جهان کوه است و فعل ما ندا\nسوی ما آید نداها را صدا`}
      translation="This world is a mountain, our actions echoes. Our echoes return to us as sound."
      attribution="Hafez"
    />
    <p class="mx-auto mt-10 max-w-md text-center font-farsi text-lg leading-[1.9] text-indigo/70">
      شعری برای هر صبح. پنج شاعر. دو زبان. قرن‌ها خرد.
    </p>
  </section>

  <SectionDivider />

  <!-- WHAT HAMDAM IS -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-fade-in class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        همدمی برای تأمل روزانه.
      </h2>
      <div class="mt-8 space-y-6 font-farsi text-lg leading-[1.9] text-indigo/90">
        <p>
          همدم هر روز، در همان ساعتی که به سراغت می‌آید، همراهت می‌شود؛ صبحی که به‌آرامی باز
          می‌شود، عصری که آرام می‌کند، شبی که روز را به آرامش می‌رساند. حال دلت را با یک حرکت
          ساده بگو، همدم شعر و تأملی متناسب با آن حس برایت می‌آورد.
        </p>
        <p>
          هر شعر با متن اصلی پارسی در کنار برگردان انگلیسی می‌آید، از حافظ، مولانا، سعدی، خیام و
          پروین اعتصامی.
        </p>
        <p>
          روزشماری آرام همراهی می‌کند که یک روز از قلم‌افتاده را می‌بخشد. هر تأمل در یادداشتی
          خصوصی نگه داشته می‌شود که از صفحه‌ی اصلی گوشی قابل جست‌وجوست، و شعرهای محبوبت همیشه در
          دسترس‌اند.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- FIVE POETS -->
  <section class="bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <h2 data-fade-in class="text-balance text-center font-farsi text-3xl font-medium text-indigo sm:text-4xl">
      پنج شاعر، پنج صدا.
    </h2>
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {poets.map((poet) => (
        <PoetCard
          persianName={poet.persianName}
          transliteration={poet.transliteration}
          description={poet.descriptionFa}
        />
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- IRANIAN CULTURAL DEPTH -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-fade-in class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        تقویم ایرانی در همدم نفس می‌کشد.
      </h2>
      <p class="mt-8 font-farsi text-lg leading-[1.9] text-indigo/90">
        یلدا در دسامبر، بلندترین شب سال که خانواده‌ها حافظ می‌خوانند. نوروز در بهار، سال نویی که
        جهان را از نو می‌سازد. چهارشنبه‌سوری، مهرگان، سیزده‌به‌در. لحظه‌های فرهنگی مثل حضوری آرام
        از راه می‌رسند، نه یادآوری تقویمی. از فال حافظ بپرس، همان‌گونه که نسل‌ها پرسیده‌اند، و
        شعری به‌عنوان پاسخ دریافت کن.
      </p>
    </div>
  </section>

  <SectionDivider />

  <!-- QUIET INTELLIGENCE -->
  <section class="bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-fade-in class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        همدم هر جا که نگاه کنی، همراه توست.
      </h2>
      <p class="mt-8 font-farsi text-lg leading-[1.9] text-indigo/90">
        از سیری بخواه تأملی را آغاز کند، شعر امروز را بشنود، یا روزشمارت را بررسی کند. ابزارکی به
        صفحه‌ی اصلی اضافه کن. اگر اپل واچ داری، شعر و روزشمارت همراهت سفر می‌کنند. اگر بخواهی، هر
        تأمل می‌تواند به‌عنوان یک ثبت حالت ذهنی در اپل هلث ذخیره شود، همراه با موسیقی آرام از اپل
        موزیک.
      </p>
    </div>
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap justify-center gap-x-10 gap-y-8">
      <FeatureIcon name="siri" label="سیری" lang="fa" />
      <FeatureIcon name="widget" label="ابزارک" lang="fa" />
      <FeatureIcon name="watch" label="اپل واچ" lang="fa" />
      <FeatureIcon name="health" label="اپل هلث" lang="fa" />
      <FeatureIcon name="music" label="اپل موزیک" lang="fa" />
    </div>
  </section>

  <SectionDivider />

  <!-- PRIVACY COMMITMENT -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-fade-in class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-farsi text-3xl font-medium text-indigo sm:text-4xl">
        همه‌چیز روی دستگاه تو می‌ماند.
      </h2>
      <p class="mt-8 font-farsi text-lg leading-[1.9] text-indigo/90">
        همدم حساب کاربری ندارد. ایمیلی جمع‌آوری نمی‌کند. اطلاعات تو را برای کسی نمی‌فرستد.
        یادداشت‌های تو فقط از طریق حساب iCloud خودت همگام‌سازی می‌شوند. بدون آمار کاربری. بدون
        تبلیغات. بدون ردیابی. فقط شعر، حضور، و فاصله‌ی میان آن دو.
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="relative flex flex-col items-center overflow-hidden px-6 py-[var(--spacing-section-mobile)] text-center sm:py-[var(--spacing-section-desktop)]">
    <div
      class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-saffron/15 blur-[120px]"
      aria-hidden="true"
    ></div>
    <PersianShamseh size={32} />
    <p class="mt-8 font-farsi text-xl leading-[1.9] text-indigo sm:text-2xl">
      با شعری بنشین. تأمل کن. فردا برگرد.
    </p>
    <div class="mt-10">
      <AppStoreBadge lang="fa" />
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-saffron/30 px-6 py-20">
    <div class="mx-auto flex max-w-xl flex-col items-center gap-4 text-center">
      <PersianShamseh size={16} opacity={0.7} />
      <HamdamLogotype size={24} showMark={false} lang="fa" />
      <p class="font-farsi text-sm text-indigo/70">اپلیکیشنی از تیم همدم</p>
      <nav aria-label="Footer" class="flex items-center gap-3 font-farsi text-sm text-indigo/70">
        <a href="/fa/privacy" class="hover:text-indigo">حریم خصوصی</a>
        <span aria-hidden="true">·</span>
        <a href="/fa/terms" class="hover:text-indigo">شرایط استفاده</a>
        <span aria-hidden="true">·</span>
        <a href="mailto:developer@hamdam.com.au" class="hover:text-indigo">تماس با ما</a>
      </nav>
      <p class="font-farsi text-sm text-indigo/70">ساخته شده با عشق در بریزبن</p>
    </div>
    <div class="mx-auto mt-10 flex max-w-xl flex-col items-center gap-2 border-t border-saffron/20 pt-8 text-center">
      <p class="text-xs text-indigo/50" lang="en" dir="ltr">&copy; {new Date().getFullYear()} Hamdam. All rights reserved.</p>
      <p class="text-xs text-indigo/50" lang="en" dir="ltr">
        HAMDAM&trade; is the subject of Australian trade mark application no. 2674427, filed 11
        July 2026.
      </p>
      <p class="text-xs text-indigo/50" lang="en" dir="ltr">
        For support, contact <a href="mailto:developer@hamdam.com.au" class="underline hover:text-indigo">developer@hamdam.com.au</a>.
      </p>
    </div>
  </footer>
</BaseLayout>
