---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersianShamseh from '../components/PersianShamseh.astro';
import AppStoreBadge from '../components/AppStoreBadge.astro';
import HeroCinematic from '../components/HeroCinematic.astro';
import VerseShowcase from '../components/VerseShowcase.astro';
import PoetCard from '../components/PoetCard.astro';
import SectionDivider from '../components/SectionDivider.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import Footer from '../components/Footer.astro';
import { poets } from '../data/poets';

const description =
  "Hamdam reflects your heart and your sky. A daily reflection companion grounded in Persian poetic wisdom, coming soon to iPhone.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Hamdam',
  description,
  operatingSystem: 'iOS',
  applicationCategory: 'LifestyleApplication',
  publisher: {
    '@type': 'Organization',
    name: 'Hamdam',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'AUD',
    description: 'Free with in-app purchases',
  },
  url: 'https://hamdam.com.au',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'developer@hamdam.com.au',
    contactType: 'customer support',
  },
};
---

<BaseLayout
  title="Hamdam — A reflection companion grounded in Persian poetic wisdom"
  description={description}
  lang="en"
  path="/"
  preloadFarsiVerse={true}
  jsonLd={jsonLd}
>
  <HeroCinematic
    lang="en"
    title="Hamdam reflects your heart and your sky."
    subhead="A bilingual reflection companion rooted in Persian poetry."
  />

  <!-- VERSE SHOWCASE -->
  <VerseShowcase
    lang="en"
    intro="A verse for every morning. Five poets. Two languages. Centuries of wisdom."
  />

  <SectionDivider />

  <!-- WHAT HAMDAM IS -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        A companion for the daily reflection.
      </h2>
      <div class="mt-8 space-y-6 font-serif text-xl leading-[1.7] text-indigo/90">
        <p>
          Every day, Hamdam meets you at the hour it finds you: a morning that opens gently, an
          afternoon that steadies, an evening that settles. Tell it how your heart feels with a
          simple slider, and it offers a verse and a reflection chosen for that feeling.
        </p>
        <p>
          Every verse arrives in its original Persian beside a careful English translation, drawn
          from Hafez, Rumi, Saadi, Khayyam and Parvin Etesami.
        </p>
        <p>
          A gentle streak keeps count, forgiving a missed day. Every reflection is kept in a
          private journal, searchable from your Home Screen, with your favourites always at hand.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- FIVE POETS -->
  <section class="bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <h2 data-reveal class="text-balance text-center font-serif text-4xl font-semibold text-indigo sm:text-5xl">
      Five poets, five voices.
    </h2>
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {poets.map((poet) => (
        <PoetCard
          persianName={poet.persianName}
          transliteration={poet.transliteration}
          description={poet.description}
        />
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- IRANIAN CULTURAL DEPTH -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        The Iranian calendar breathes through Hamdam.
      </h2>
      <p class="mt-8 font-serif text-xl leading-[1.7] text-indigo/90">
        Yalda in December, the longest night when families read Hafez together. Norooz in spring,
        the new year that renews the world. Chaharshanbe Suri, Mehregan, Sizdah Bedar. Cultural
        moments arrive as gentle presences, not calendar reminders. Ask the Fal e Hafez a question
        the way generations have, and receive a verse in answer.
      </p>
    </div>
  </section>

  <SectionDivider />

  <!-- QUIET INTELLIGENCE -->
  <section class="bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        Hamdam meets you wherever you look.
      </h2>
      <p class="mt-8 font-serif text-xl leading-[1.7] text-indigo/90">
        Ask Siri to start a reflection, hear today's verse, or check your streak. Add a widget to
        your Home Screen. If you wear an Apple Watch, your verse and streak travel with you. If
        you choose, each reflection can be saved to Apple Health as a State of Mind entry, with
        calm music playing alongside through Apple Music.
      </p>
    </div>
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap justify-center gap-x-10 gap-y-8">
      <FeatureIcon name="siri" label="Siri" />
      <FeatureIcon name="widget" label="Widgets" />
      <FeatureIcon name="watch" label="Watch" />
      <FeatureIcon name="health" label="Health" />
      <FeatureIcon name="music" label="Music" />
    </div>
  </section>

  <SectionDivider />

  <!-- PRIVACY COMMITMENT -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        Everything stays on your device.
      </h2>
      <p class="mt-8 font-serif text-xl leading-[1.7] text-indigo/90">
        Hamdam does not use accounts. Does not collect emails. Does not send your data to anyone.
        Your journal entries sync only via your own iCloud account. No analytics. No advertising.
        No tracking. Just poetry, presence, and the space between.
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="relative flex flex-col items-center overflow-hidden px-6 py-[var(--spacing-section-mobile)] text-center sm:py-[var(--spacing-section-desktop)]">
    <div
      class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-saffron/15 blur-[120px]"
      aria-hidden="true"
    ></div>
    <PersianShamseh size={32} />
    <p class="mt-8 font-serif text-2xl italic text-indigo sm:text-[26px]">
      Sit with a verse. Reflect. Return tomorrow.
    </p>
    <div class="mt-10">
      <AppStoreBadge />
    </div>
  </section>

  <Footer />
</BaseLayout>
