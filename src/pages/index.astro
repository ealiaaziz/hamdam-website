---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCinematic from '../components/HeroCinematic.astro';
import MoodDemo from '../components/MoodDemo.astro';
import VerseShowcase from '../components/VerseShowcase.astro';
import PoetsBand from '../components/PoetsBand.astro';
import ContextConstellation from '../components/ContextConstellation.astro';
import JourneyPair from '../components/JourneyPair.astro';
import RootsMoments from '../components/RootsMoments.astro';
import PrivacyTrust from '../components/PrivacyTrust.astro';
import PlansAndFoundingCompanion from '../components/PlansAndFoundingCompanion.astro';
import FinalCeremony from '../components/FinalCeremony.astro';
import SectionDivider from '../components/SectionDivider.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import Footer from '../components/Footer.astro';
import SceneBackground from '../components/SceneBackground.astro';
import quietGarden from '../assets/scenes/quiet-garden-section.jpg';
import dawn from '../assets/scenes/dawn-section.jpg';

const description =
  "Hamdam reflects your heart and your sky. A daily reflection companion grounded in Persian poetic wisdom, available now on iPhone.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hamdam',
  alternateName: 'Hamdam: Poetry and Reflections',
  description,
  operatingSystem: 'iOS 26+',
  applicationCategory: 'LifestyleApplication',
  url: 'https://hamdam.com.au/',
  inLanguage: ['en', 'fa'],
  publisher: {
    '@type': 'Organization',
    name: 'Hamdam',
  },
  // Paid-tier prices intentionally not published (decision 2026-07-02).
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'AUD',
    description: 'Free with in-app purchases',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'developer@hamdam.com.au',
    contactType: 'customer support',
  },
};
---

<BaseLayout
  title="Hamdam: A reflection companion grounded in Persian poetic wisdom"
  description={description}
  lang="en"
  path="/"
  preloadFarsiVerse={true}
  jsonLd={jsonLd}
>
  <HeroCinematic
    lang="en"
    title="Hamdam reflects your heart and your sky."
    subhead="A bilingual reflection companion rooted in Persian poetry."
  />

  <MoodDemo lang="en" />

  <!-- VERSE SHOWCASE -->
  <VerseShowcase
    lang="en"
    intro="A verse for every morning. Five poets. Two languages. Centuries of wisdom."
    sceneImage={dawn}
  />

  <SectionDivider />

  <!-- WHAT HAMDAM IS -->
  <section class="px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        A companion for the daily reflection.
      </h2>
      <div class="mt-8 space-y-6 font-serif text-xl leading-[1.7] text-indigo/90">
        <p>
          Every day, Hamdam meets you at the hour it finds you: a morning that opens gently, an
          afternoon that steadies, an evening that settles. Tell it how your heart feels with a
          simple slider, and it offers a verse and a reflection chosen for that feeling.
        </p>
        <p>
          Every verse arrives in its original Persian beside a careful English translation, drawn
          from Hafez, Rumi, Saadi, Khayyam and Parvin Etesami.
        </p>
        <p>
          A gentle streak keeps count, forgiving a missed day. Every reflection is kept in a
          private journal, searchable from your Home Screen, with your favourites always at hand.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- FIVE POETS -->
  <PoetsBand lang="en" />

  <!-- CONTEXT CONSTELLATION -->
  <ContextConstellation lang="en" />

  <!-- YOUR JOURNEY -->
  <JourneyPair lang="en" />

  <SectionDivider />

  <!-- ROOTS AND REGION -->
  <RootsMoments lang="en" />

  <SectionDivider />

  <!-- QUIET INTELLIGENCE -->
  <section class="relative bg-gradient-to-b from-peach/15 via-peach/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <SceneBackground image={quietGarden} />
    <div data-reveal class="relative mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        Hamdam meets you wherever you look.
      </h2>
      <p class="mt-8 font-serif text-xl leading-[1.7] text-indigo/90">
        Ask Siri to start a reflection, hear today's verse, or check your streak. Add a widget to
        your Home Screen. If you wear an Apple Watch, your verse and streak travel with you. If
        you choose, each reflection can be saved to Apple Health as a State of Mind entry, with
        calm music playing alongside through Apple Music.
      </p>
    </div>
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap justify-center gap-x-10 gap-y-8">
      <FeatureIcon name="siri" label="Siri" />
      <FeatureIcon name="widget" label="Widgets" />
      <FeatureIcon name="watch" label="Watch" />
      <FeatureIcon name="health" label="Health" />
      <FeatureIcon name="music" label="Music" />
    </div>
  </section>

  <SectionDivider />

  <!--
    QUIET COMPANIONS
    DRAFT copy, added 2026-07-20, not yet in docs/website-redesign/32-fable-approved-copy-ledger.md.
    Grounded in hamdam-ios docs/progress.md Phase 20 (Family Sharing) and Phase 27+28+29
    (Mental Companion, Fitness Companion, Interactive Calendar) -- all shipped, opt-in,
    default-off features with no equivalent section anywhere else on this site (checked via
    repo-wide grep for "companion"/"calendar"/"family" before writing this). Needs the same
    Ealia sign-off pass as every other section's copy before being considered approved; not
    self-approving it here.
  -->
  <section class="relative bg-gradient-to-b from-indigo/10 via-indigo/5 to-transparent px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
    <div data-reveal class="relative mx-auto max-w-[var(--container-reading)]">
      <h2 class="text-balance font-serif text-4xl font-semibold text-indigo sm:text-5xl">
        A few quiet companions, if you want them.
      </h2>
      <p class="mt-8 font-serif text-xl leading-[1.7] text-indigo/90">
        Everything below is optional and off by default. A gentle mental companion notices
        patterns in how you have been feeling and offers a passing observation, never advice. A
        separate fitness companion sits alongside your own activity, entirely apart from Apple
        Fitness, and only ever opens what you ask it to. If you would like reflection to have a
        place in your day, Hamdam can keep its own calendar, entirely its own, holding
        reflection moments and the cultural dates you care about without ever touching your
        existing calendar. And Family Sharing works the way Apple already intends, no extra
        permissions to grant.
      </p>
    </div>
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap justify-center gap-x-10 gap-y-8">
      <FeatureIcon name="companion" label="Companions" />
      <FeatureIcon name="calendar" label="Calendar" />
      <FeatureIcon name="family" label="Family Sharing" />
    </div>
  </section>

  <!--
    MORE TO COME
    DRAFT copy, added 2026-07-20. Deliberately makes no specific feature claim, so it needs
    no product-truth verification and no re-check as the roadmap changes -- see
    docs/website-redesign/22-dependency-decision.md's sibling caution about not marketing
    anything unshipped (Apple Intelligence is the concrete example on file). This is scoped
    to stay true indefinitely rather than naming anything that could go stale or leak an
    unannounced feature. Still draft copy, same sign-off expectation as the rest of this page.
  -->
  <section class="px-6 py-16 text-center sm:py-20">
    <div data-reveal class="mx-auto max-w-[var(--container-reading)]">
      <p class="font-serif text-2xl italic text-indigo/80 sm:text-3xl">
        Hamdam is still becoming.
      </p>
      <p class="mt-4 font-serif text-lg leading-[1.7] text-indigo/60">
        This is where it stands today. There is more still arriving, quietly, the way mornings
        do.
      </p>
    </div>
  </section>

  <SectionDivider />

  <!-- PRIVACY -->
  <PrivacyTrust lang="en" />

  <!-- PLANS AND FOUNDING COMPANION -->
  <PlansAndFoundingCompanion lang="en" />

  <!-- FINAL CEREMONY -->
  <FinalCeremony lang="en" />

  <Footer />
</BaseLayout>
