---
import PersianShamseh from './PersianShamseh.astro';
import AppStoreBadge from './AppStoreBadge.astro';
import { starField } from '../lib/cinematic';

interface Props {
  lang: 'en' | 'fa';
  title: string;
  subhead: string;
}

const { lang, title, subhead } = Astro.props;
// Deterministic star field (seed 42 by spec), rendered at build time so the
// client never computes positions and they can never jitter.
const stars = starField(40, 42);

// Real device screenshot alt text ("Hamdam Today screen showing a morning
// verse by [poet]...") is written once the orchestrator asset lands
// (page spec §2 item 11); this placeholder alt is honest about the
// current state rather than describing content that isn't there yet.
const deviceAlt =
  lang === 'fa'
    ? 'پیش‌نمایش صفحه اصلی همدم (تصویر نهایی در دست تهیه)'
    : 'Hamdam Today screen preview (final screenshot pending)';
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__viewport">
    <div class="hero__sky" aria-hidden="true">
      <svg
        class="hero__stars"
        viewBox="0 0 1000 650"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {stars.map((s) => (
          <circle cx={s.x * 10} cy={s.y * 10} r={s.r * 1.6} fill="#F5EEE0" opacity={s.o} />
        ))}
      </svg>
      <div class="hero__sun-track" aria-hidden="true">
        <div class="hero__sun"></div>
      </div>
      {
        /* TODO(HW-01/HW-02/HW-03): replace this CSS-gradient horizon with the
           photographic sky plates once produced (20-implementation-plan.md
           Phase 3 required assets). Not a stock substitute -- an abstract
           atmospheric tint that predates the redesign and needs no asset. */
      }
      <div class="hero__horizon"></div>
    </div>

    <div class="hero__content">
      <PersianShamseh size={64} color="currentColor" />
      <h1 id="hero-title" class="hero__title text-balance">{title}</h1>
      <p class="hero__sub text-balance">{subhead}</p>
      <div class="hero__cta" data-store-cta="hero">
        <AppStoreBadge lang={lang} />
      </div>

      {
        /* DV-01 (device frame) + orchestrator 01-hero-{lang}.png are both
           pending (see docs/website-redesign/22-dependency-decision.md).
           Labelled solid-tone placeholder per the plan's asset-gate rule:
           never a stock image, never an invented screen. Swap the fill for
           <img src={deviceFrame} ...> once both assets land. */
      }
      <div class="hero__device" role="img" aria-label={deviceAlt}>
        {import.meta.env.DEV && <span class="hero__device-label">DV-01 pending</span>}
      </div>
    </div>
  </div>
</section>

{/* TODO(HW-04): desktop-only foreground blossom plate, pending Canva production. Omitted entirely for now -- mobile never shows this layer, so its absence changes nothing there, and desktop's composition still reads correctly without it. */}

<style>
  /*
    Phase 3 (20-implementation-plan.md): this static composition IS the
    reduced-motion target state (page spec §2 item 8) -- first-light,
    fully legible, no settle-in, no scroll-linked motion. Phase 4 restores
    the night-to-morning scroll arc for motion-OK visitors on top of this;
    until then every visitor (motion or reduced-motion) sees the same
    warm, complete state.
  */
  .hero {
    min-height: 100vh;
    --sky-top: #E8B04B;
    --sky-bot: #F5EEE0;
    --sun-y: -10%;
    --sun-glow: 24px;
    --stars-o: 0;
    --haze-o: 0.12;
    --hero-text: var(--hamdam-text);
    --title-shadow-o: 0;
    --scrim-o: 0;
  }

  .hero__viewport {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: 6.5rem 2rem;
    padding-inline: 1.5rem;
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to bottom, var(--sky-top), var(--sky-bot));
  }

  .hero__stars {
    display: none;
  }

  .hero__sun-track {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    height: 76%;
    overflow: hidden;
  }

  .hero__sun {
    position: absolute;
    bottom: 0;
    inset-inline-start: 10%;
    width: clamp(72px, 9vw, 112px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 40%, var(--hamdam-saffron), var(--hamdam-ember) 78%);
    box-shadow: 0 0 var(--sun-glow) rgb(232 176 75 / 0.5);
    transform: translateY(var(--sun-y));
  }

  .hero__horizon {
    position: absolute;
    top: 70%;
    inset-inline: 0;
    height: 14%;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--hamdam-mist-amber-grey) 45%,
      transparent
    );
    opacity: var(--haze-o);
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    color: var(--hero-text);
  }

  .hero__title {
    margin-top: 2.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-display);
    line-height: 1.05;
  }

  :global([lang='fa']) .hero__title {
    font-family: var(--font-farsi);
    font-weight: 500;
    font-size: var(--text-display-fa);
    line-height: 1.25;
  }

  .hero__sub {
    margin-top: 2rem;
    max-width: 36rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.7;
    opacity: 0.9;
  }

  :global([lang='fa']) .hero__sub {
    font-family: var(--font-farsi);
    font-style: normal;
    line-height: 1.9;
  }

  .hero__cta {
    margin-top: 3rem;
  }

  .hero__device {
    margin-top: 3rem;
    width: min(260px, 62vw);
    aspect-ratio: 1290 / 2796;
    border-radius: var(--radius-device);
    background: linear-gradient(to bottom, var(--surface-dusk), var(--surface-firstlight));
    box-shadow: var(--shadow-lift);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .hero__device {
      width: min(360px, 32vw);
    }
  }

  .hero__device-label {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-on-night-muted);
    padding: 0 1rem;
    text-align: center;
  }
</style>
