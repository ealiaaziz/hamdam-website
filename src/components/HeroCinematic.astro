---
import PersianShamseh from './PersianShamseh.astro';
import AppStoreBadge from './AppStoreBadge.astro';
import { starField } from '../lib/cinematic';

interface Props {
  lang: 'en' | 'fa';
  title: string;
  subhead: string;
}

const { lang, title, subhead } = Astro.props;
// Deterministic star field (seed 42 by spec), rendered at build time so the
// client never computes positions and they can never jitter.
const stars = starField(40, 42);
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__viewport">
    <div class="hero__sky" aria-hidden="true">
      <svg
        class="hero__stars"
        viewBox="0 0 1000 650"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {stars.map((s) => (
          <circle cx={s.x * 10} cy={s.y * 10} r={s.r * 1.6} fill="#F5EEE0" opacity={s.o} />
        ))}
      </svg>
      <div class="hero__sun-track" aria-hidden="true">
        <div class="hero__sun"></div>
      </div>
      <div class="hero__horizon"></div>
    </div>

    <div class="hero__content">
      <PersianShamseh size={64} animated={true} color="currentColor" />
      <h1 id="hero-title" class="hero__title text-balance">{title}</h1>
      <p class="hero__sub text-balance">{subhead}</p>
      <div class="hero__cta">
        <AppStoreBadge lang={lang} />
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Custom-property defaults describe deep NIGHT (progress 0): that is what a
    motion-enabled visitor sees on load, so the scroll script's first write is
    a no-op and there is no flash. Reduced-motion visitors get the static
    MORNING state via the media query below, per the Phase 4.4 spec.
  */
  .hero {
    height: 200vh;
    --sky-top: #1a1611;
    --sky-bot: #241e15;
    --sun-y: 115%;
    --sun-glow: 0px;
    --stars-o: 1;
    --haze-o: 0;
    --hero-text: var(--hamdam-dawn-cream);
    --title-shadow-o: 0.28;
    --scrim-o: 0;
  }

  .hero__viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-inline: 1.5rem;
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to bottom, var(--sky-top), var(--sky-bot));
    contain: strict;
  }

  .hero__stars {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    width: 100%;
    height: 65%;
    opacity: var(--stars-o);
  }

  /* Clips the sun below the horizon line so "risen" is literal. */
  .hero__sun-track {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    height: 76%;
    overflow: hidden;
  }

  .hero__sun {
    position: absolute;
    bottom: 0;
    inset-inline-start: 10%;
    width: clamp(72px, 9vw, 112px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 40%, var(--hamdam-saffron), var(--hamdam-ember) 78%);
    box-shadow: 0 0 var(--sun-glow) rgb(232 160 61 / 0.5);
    transform: translateY(var(--sun-y));
  }

  .hero__horizon {
    position: absolute;
    top: 70%;
    inset-inline: 0;
    height: 14%;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--hamdam-mist-amber-grey) 45%,
      transparent
    );
    opacity: var(--haze-o);
  }

  .hero--in-view .hero__sun,
  .hero--in-view .hero__stars {
    will-change: transform, opacity;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    color: var(--hero-text);
    /* Mid-dawn contrast scrim — invisible at both ends of the timeline. */
    background: rgb(26 22 17 / var(--scrim-o));
    border-radius: var(--radius-card, 16px);
    padding: 1.5rem 2rem;
  }

  .hero__title {
    margin-top: 2.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 1.05;
    /* Soft ground for the mid-dawn frames where sky and text values converge;
       dissolves via --title-shadow-o as the sky lightens. */
    text-shadow: 0 1px 28px rgb(26 22 17 / var(--title-shadow-o));
  }

  :global([lang='fa']) .hero__title {
    font-family: var(--font-farsi);
    font-weight: 500;
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1.3;
  }

  .hero__sub {
    margin-top: 2rem;
    max-width: 36rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.7;
    opacity: 0.9;
  }

  :global([lang='fa']) .hero__sub {
    font-family: var(--font-farsi);
    font-style: normal;
    line-height: 1.9;
  }

  .hero__cta {
    margin-top: 3rem;
  }

  /* Entrance choreography — motion-enabled visitors only. One-time settle,
     no infinite pulse. */
  @media (prefers-reduced-motion: no-preference) {
    .hero__title,
    .hero__sub,
    .hero__cta {
      opacity: 0;
      animation: hero-rise var(--dur-reveal) var(--ease-dawn) forwards;
    }
    .hero__title { animation-delay: 200ms; }
    .hero__sub { animation-delay: 500ms; }
    .hero__cta { animation-delay: 800ms; }
  }

  /* ?dawn=N design-review mode: timeline pinned, entrance pre-settled so
     screenshots are deterministic. */
  .hero--settled .hero__title,
  .hero--settled .hero__sub,
  .hero--settled .hero__cta {
    animation: none;
    opacity: 1;
    transform: none;
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduced motion: static MORNING scene, no stars, no transitions (4.4). */
  @media (prefers-reduced-motion: reduce) {
    .hero {
      height: 100vh;
      --sky-top: #e8a03d;
      --sky-bot: #f5eee0;
      --sun-y: -10%;
      --sun-glow: 24px;
      --stars-o: 0;
      --haze-o: 0.12;
      --hero-text: var(--hamdam-text);
      --title-shadow-o: 0;
      --scrim-o: 0;
    }
    .hero__stars {
      display: none;
    }
    .hero__title {
      text-shadow: none;
    }
  }
</style>

<script>
  import {
    gradientForProgress,
    sunYForProgress,
    sunGlowForProgress,
    starsOpacityForProgress,
    hazeOpacityForProgress,
    textColorForProgress,
    titleShadowOpacityForProgress,
    scrimOpacityForProgress,
    prefersReducedMotion,
  } from '../lib/cinematic';

  const hero = document.getElementById('hero');

  if (hero && !prefersReducedMotion()) {
    const style = hero.style;

    const apply = (p: number) => {
      const g = gradientForProgress(p);
      style.setProperty('--sky-top', g.top);
      style.setProperty('--sky-bot', g.bot);
      style.setProperty('--sun-y', `${sunYForProgress(p)}%`);
      style.setProperty('--sun-glow', `${sunGlowForProgress(p)}px`);
      style.setProperty('--stars-o', String(starsOpacityForProgress(p)));
      style.setProperty('--haze-o', String(hazeOpacityForProgress(p)));
      style.setProperty('--hero-text', textColorForProgress(p));
      style.setProperty('--title-shadow-o', String(titleShadowOpacityForProgress(p)));
      style.setProperty('--scrim-o', String(scrimOpacityForProgress(p)));
    };

    // ?dawn=0.65 pins the timeline for design review and screenshots.
    const pinned = new URLSearchParams(window.location.search).get('dawn');
    if (pinned !== null && !Number.isNaN(Number(pinned))) {
      hero.classList.add('hero--settled');
      apply(Math.max(0, Math.min(1, Number(pinned))));
    } else {
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          apply(Math.max(0, Math.min(1, window.scrollY / window.innerHeight)));
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // will-change only while the hero is on screen (4.5).
      new IntersectionObserver((entries) => {
        for (const entry of entries) {
          hero.classList.toggle('hero--in-view', entry.isIntersecting);
        }
      }).observe(hero);
    }
  }
</script>
