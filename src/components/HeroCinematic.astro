---
import { Image } from 'astro:assets';
import PersianShamseh from './PersianShamseh.astro';
import AppStoreBadge from './AppStoreBadge.astro';
import { starField } from '../lib/cinematic';
import heroHorizonDesktop from '../assets/website-redesign/hero-horizon-desktop.png';
import heroHorizonMobile from '../assets/website-redesign/hero-horizon-mobile.png';
import heroBlossomForeground from '../assets/website-redesign/hero-blossom-foreground.png';
import deviceFrame from '../assets/website-redesign/device-frame-iphone.png';
import heroScreenshotEn from '../assets/website-redesign/screenshots/EN/01-hero-en.png';
import heroScreenshotFa from '../assets/website-redesign/screenshots/FA/01-hero-fa.png';

interface Props {
  lang: 'en' | 'fa';
  title: string;
  subhead: string;
}

const { lang, title, subhead } = Astro.props;
// Deterministic star field (seed 42 by spec), rendered at build time so the
// client never computes positions and they can never jitter.
const stars = starField(40, 42);

// Real orchestrator screenshot landed 2026-07-19 (see
// docs/app-store/phase-3-screenshot-orchestrator.md's "raw, uncomposed"
// set -- NOT the composed App-Store marketing PNGs, which already have
// their own baked-in phone mockup and would double-frame here): the Today
// screen, seeded with the hafez-015 verse (ScreenshotSeedData.swift's
// heroVerse).
const heroScreenshot = lang === 'fa' ? heroScreenshotFa : heroScreenshotEn;
const deviceAlt =
  lang === 'fa'
    ? 'نمای صفحه اصلی همدم با شعری صبحگاهی از حافظ'
    : 'Hamdam Today screen showing a morning verse by Hafez';
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__viewport">
    <div class="hero__sky" aria-hidden="true">
      <svg
        class="hero__stars"
        viewBox="0 0 1000 650"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {stars.map((s) => (
          <circle cx={s.x * 10} cy={s.y * 10} r={s.r * 1.6} fill="#F5EEE0" opacity={s.o} />
        ))}
      </svg>
      <div class="hero__sun-track" aria-hidden="true">
        <div class="hero__sun"></div>
      </div>
      {
        /* HW-01/HW-02 (14-canva-asset-brief.md): photographic horizon plate,
           desktop vs mobile recomposition, swapped by CSS breakpoint (768px,
           this repo's md breakpoint per StickyDownloadAction.astro's own
           convention). Each asset's own alpha channel already carries the
           top-fade-to-transparent gradient the brief requires, so no extra
           masking is needed here -- just placement and the existing
           scroll-linked drift. Flipped under RTL per the brief's own
           acceptance criterion ("mirrors cleanly when flipped horizontally
           for RTL"). .hero__horizon (the ambient haze band) is kept
           unchanged underneath as a separate atmospheric layer, not
           replaced -- it is not a stand-in for the photo, see its own
           comment below. */
      }
      <Image
        src={heroHorizonDesktop}
        alt=""
        width={heroHorizonDesktop.width}
        height={heroHorizonDesktop.height}
        loading="eager"
        fetchpriority="high"
        class="hero__horizon-photo hero__horizon-photo--desktop"
      />
      <Image
        src={heroHorizonMobile}
        alt=""
        width={heroHorizonMobile.width}
        height={heroHorizonMobile.height}
        loading="eager"
        fetchpriority="high"
        class="hero__horizon-photo hero__horizon-photo--mobile"
      />
      {
        /* HW-04: desktop-only foreground blossom plate. Dropped on mobile
           per the page spec -- there is no HW-04 mobile variant, this is
           not an oversight. Real alpha edges (no halo), so no additional
           masking needed. */
      }
      <Image
        src={heroBlossomForeground}
        alt=""
        width={heroBlossomForeground.width}
        height={heroBlossomForeground.height}
        class="hero__blossom-photo"
      />
      {
        /* Ambient haze band (predates the redesign, no asset dependency --
           see the original TODO this replaced, now resolved above). */
      }
      <div class="hero__horizon"></div>
    </div>

    <div class="hero__content">
      <PersianShamseh size={64} color="currentColor" class="hero__mark" />
      <h1 id="hero-title" class="hero__title text-balance">{title}</h1>
      <p class="hero__sub text-balance">{subhead}</p>
      <div class="hero__cta" data-store-cta="hero">
        <AppStoreBadge lang={lang} />
      </div>

      {
        /* Real orchestrator screenshot composited 2026-07-19 behind the
           frame, through its transparent screen cutout (per the frame's
           own brief, 14-canva-asset-brief.md). Cutout position measured
           directly from device-frame-iphone.png's alpha channel (connected
           transparent region from centre: left 6.43%, top 5.97%, right
           6.07%, bottom 6.41% of the frame's own box) -- not eyeballed,
           and reused identically by every other DV-01 consumer since they
           all share the same 1290/2796 container aspect-ratio and
           object-fit: contain frame rendering. Verified by local
           composite render before wiring (grey-canvas standin, no live
           browser available this session) -- single clean device mockup,
           no double-framing, background full-bleed. */
      }
      <div class="hero__device" role="img" aria-label={deviceAlt}>
        <Image
          src={heroScreenshot}
          alt=""
          width={945}
          height={2052}
          quality={80}
          class="hero__device-screen"
        />
        {
          /* On-page display never exceeds 360px CSS width (.hero__device's
             own max), so 720px (2x retina headroom) is the real budget-
             relevant output size -- the full 1400x2820 source stays intact
             on disk per the brief's exact-dimensions requirement, only the
             on-page render is scaled down, same "compression owner:
             implementation session" split the brief specifies for every
             asset. */
        }
        <Image
          src={deviceFrame}
          alt=""
          width={600}
          height={Math.round((600 / deviceFrame.width) * deviceFrame.height)}
          quality={72}
          class="hero__device-frame"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Phase 3 defaults (unchanged): first-light, matching what reduced-motion
    visitors see permanently (page spec §2 item 8). Phase 4's script
    overrides these via inline custom properties for motion-OK visitors,
    starting from night and brightening across the first viewport of
    scroll; reduced-motion visitors keep these exact defaults except for
    instant (non-interpolated) threshold jumps -- see the script below.
  */
  .hero {
    /* Own stacking context: without this, .hero__sky's z-index: -1 (and
       its position: absolute, lacking a positioned ancestor otherwise)
       compares against the ROOT stacking context instead of staying
       scoped to the hero -- exactly the bug that let the page-level
       SkySurface (Phase 4) bleed through unpredictably. */
    position: relative;
    isolation: isolate;
    height: 200vh;
    --sky-top: #E8B04B;
    --sky-bot: #F5EEE0;
    --sun-y: -10%;
    --sun-glow: 24px;
    --stars-o: 0;
    --haze-o: 0.12;
    --hero-text: var(--hamdam-text);
    --title-shadow-o: 0;
    --scrim-o: 0;
    --horizon-drift: 0px;
    --device-drift: 0px;
  }

  .hero__viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: 6.5rem 2rem;
    padding-inline: 1.5rem;
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to bottom, var(--sky-top), var(--sky-bot));
  }

  .hero__stars {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    width: 100%;
    height: 65%;
    opacity: var(--stars-o);
  }

  .hero__sun-track {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    height: 76%;
    overflow: hidden;
  }

  .hero__sun {
    position: absolute;
    bottom: 0;
    inset-inline-start: 10%;
    width: clamp(72px, 9vw, 112px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 40%, var(--hamdam-saffron), var(--hamdam-ember) 78%);
    box-shadow: 0 0 var(--sun-glow) rgb(232 176 75 / 0.5);
    transform: translateY(var(--sun-y));
  }

  .hero__horizon {
    position: absolute;
    top: 70%;
    inset-inline: 0;
    height: 14%;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--hamdam-mist-amber-grey) 45%,
      transparent
    );
    opacity: var(--haze-o);
    transform: translateY(var(--horizon-drift));
  }

  .hero__horizon-photo {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    width: 100%;
    height: auto;
    transform: translateY(var(--horizon-drift));
  }
  :global([dir='rtl']) .hero__horizon-photo {
    transform: scaleX(-1) translateY(var(--horizon-drift));
  }

  .hero__horizon-photo--desktop {
    display: none;
  }
  .hero__horizon-photo--mobile {
    display: block;
  }
  @media (min-width: 768px) {
    .hero__horizon-photo--desktop {
      display: block;
    }
    .hero__horizon-photo--mobile {
      display: none;
    }
  }

  .hero__blossom-photo {
    display: none;
  }
  @media (min-width: 768px) {
    .hero__blossom-photo {
      display: block;
      position: absolute;
      inset-inline-start: 0;
      bottom: 0;
      width: min(32%, 420px);
      height: auto;
      transform: translateY(calc(var(--horizon-drift) * 1.5));
    }
    :global([dir='rtl']) .hero__blossom-photo {
      transform: scaleX(-1) translateY(calc(var(--horizon-drift) * 1.5));
    }
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    color: var(--hero-text);
  }

  .hero__title {
    margin-top: 2.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-display);
    line-height: 1.05;
  }

  :global([lang='fa']) .hero__title {
    font-family: var(--font-farsi);
    font-weight: 500;
    font-size: var(--text-display-fa);
    line-height: 1.25;
  }

  .hero__sub {
    margin-top: 2rem;
    max-width: 36rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.7;
    opacity: 0.9;
  }

  :global([lang='fa']) .hero__sub {
    font-family: var(--font-farsi);
    font-style: normal;
    line-height: 1.9;
  }

  .hero__cta {
    margin-top: 3rem;
  }

  .hero__device {
    position: relative;
    margin-top: 3rem;
    width: min(260px, 62vw);
    aspect-ratio: 1290 / 2796;
    border-radius: var(--radius-device);
    background: linear-gradient(to bottom, var(--surface-dusk), var(--surface-firstlight));
    box-shadow: var(--shadow-lift);
    overflow: hidden;
    transform: translateY(var(--device-drift));
  }

  .hero__device-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero__device-screen {
    position: absolute;
    top: 5.97%;
    right: 6.07%;
    bottom: 6.41%;
    left: 6.43%;
    width: auto;
    height: auto;
    object-fit: cover;
    border-radius: 8%;
  }

  @media (min-width: 640px) {
    .hero__device {
      width: min(360px, 32vw);
    }
  }

  .hero--in-view .hero__sun,
  .hero--in-view .hero__stars {
    will-change: transform, opacity;
  }

  /* One-time settle-in on load (motion-specification.md §3): mark, title,
     sub, CTA, device rise 12px and fade in, staggered 80ms, 600ms total.
     Motion-OK only; reduced-motion renders the final state immediately
     (no keyframes run at all, so "no settle-in" is exact, not just fast). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__mark,
    .hero__title,
    .hero__sub,
    .hero__cta,
    .hero__device {
      opacity: 0;
      animation: hero-settle 600ms var(--ease-settle) forwards;
    }
    .hero__mark { animation-delay: 0ms; }
    .hero__title { animation-delay: 80ms; }
    .hero__sub { animation-delay: 160ms; }
    .hero__cta { animation-delay: 240ms; }
    .hero__device { animation-delay: 320ms; }
  }

  /* ?dawn=N design-review mode: timeline pinned, entrance pre-settled so
     screenshots are deterministic. */
  .hero--settled .hero__mark,
  .hero--settled .hero__title,
  .hero--settled .hero__sub,
  .hero--settled .hero__cta,
  .hero--settled .hero__device {
    animation: none;
    opacity: 1;
    transform: none;
  }

  @keyframes hero-settle {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  import {
    gradientForProgress,
    sunYForProgress,
    sunGlowForProgress,
    starsOpacityForProgress,
    hazeOpacityForProgress,
    textColorForProgress,
    titleShadowOpacityForProgress,
    scrimOpacityForProgress,
    prefersReducedMotion,
  } from '../lib/cinematic';

  const hero = document.getElementById('hero');

  // Reduced motion: this script does not run at all. Phase 3's static CSS
  // defaults on .hero already ARE the exact first-light state ("warm,
  // legible, complete", page spec §2 item 8) -- not a low-progress point
  // on this continuous ramp, which is still quite dark until well past
  // p=0.5. Leaving those defaults completely untouched is simpler and more
  // correct than trying to reproduce "first-light" by quantizing progress.
  if (hero && !prefersReducedMotion()) {
    const style = hero.style;
    const navBar = document.querySelector<HTMLElement>('[data-nav-bar]');
    // textColorForProgress returns lerpHex output ("rgb(r g b)"), never a
    // raw hex string -- this must match that exact format.
    const DARK_TEXT = 'rgb(36 30 21)';

    const apply = (p) => {
      const g = gradientForProgress(p);
      style.setProperty('--sky-top', g.top);
      style.setProperty('--sky-bot', g.bot);
      style.setProperty('--sun-y', `${sunYForProgress(p)}%`);
      style.setProperty('--sun-glow', `${sunGlowForProgress(p)}px`);
      style.setProperty('--stars-o', String(starsOpacityForProgress(p)));
      style.setProperty('--haze-o', String(hazeOpacityForProgress(p)));
      const heroText = textColorForProgress(p);
      style.setProperty('--hero-text', heroText);
      style.setProperty('--title-shadow-o', String(titleShadowOpacityForProgress(p)));
      style.setProperty('--scrim-o', String(scrimOpacityForProgress(p)));

      // Depth-cueing drift (motion-specification.md §3): horizon at 8% of
      // the hero's own 0-to-1-viewport scroll range; device settles over
      // the last 24px of its rise.
      const vh = window.innerHeight;
      style.setProperty('--horizon-drift', `${(1 - p) * 0.08 * vh}px`);
      style.setProperty('--device-drift', `${(1 - p) * 24}px`);

      // Nav text tracks the same flip as the hero's own text (transparent
      // over whatever the hero currently shows behind it): dark ink once
      // the sky is light enough to hold it, cream otherwise.
      navBar?.classList.toggle('nav-bar--on-light', heroText === DARK_TEXT);
    };

    // ?dawn=0.65 pins the timeline for design review and screenshots.
    const pinned = new URLSearchParams(window.location.search).get('dawn');
    if (pinned !== null && !Number.isNaN(Number(pinned))) {
      hero.classList.add('hero--settled');
      apply(Math.max(0, Math.min(1, Number(pinned))));
    } else {
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          apply(Math.max(0, Math.min(1, window.scrollY / window.innerHeight)));
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // will-change only while the hero is on screen.
      new IntersectionObserver((entries) => {
        for (const entry of entries) {
          hero.classList.toggle('hero--in-view', entry.isIntersecting);
        }
      }).observe(hero);
    }
  }
</script>
