---
import { Image } from 'astro:assets';
import deviceFrame from '../assets/website-redesign/device-frame-iphone.png';

interface Props {
  lang: 'en' | 'fa';
}

const { lang } = Astro.props;

// Every clause here is traceable to the live Privacy Policy (page spec §8
// item 4): the primary statement mirrors /privacy's own opening
// paragraph; the trust row's three items map to "no accounts" (§2),
// "on your device" (§1's opening: "a small set of signals, on your own
// device"), and "your own iCloud only" (§1.4, opt-in, CloudKit Private
// Database, scoped to the visitor's own Apple ID).
const copy =
  lang === 'fa'
    ? {
        statement: 'همدم از حساب کاربری استفاده نمی‌کند. ایمیلی جمع‌آوری نمی‌کند. کلمات تو هرگز از دستگاهت خارج نمی‌شوند، مگر اینکه خودت همگام‌سازی iCloud را روشن کنی. هیچ‌کس در همدم نمی‌تواند حتی یک کلمه از نوشته‌های تو را بخواند.',
        trust: [
          { title: 'بدون حساب کاربری', body: 'بدون ثبت‌نام، بدون ایمیل.' },
          { title: 'روی دستگاه خودت', body: 'سیگنال‌ها همان‌جا که خوانده شدند می‌مانند.' },
          { title: 'فقط iCloud خودت', body: 'همگام‌سازی اختیاری است، فقط برای Apple ID خودت.' },
        ],
        links: { privacy: 'حریم خصوصی', terms: 'شرایط استفاده' },
        deviceAlt: 'صفحه حریم خصوصی همدم (تصویر نهایی در دست تهیه)',
      }
    : {
        statement: 'Hamdam does not use accounts. It does not collect emails. Your words never leave your device unless you turn on your own iCloud sync. Nobody at Hamdam can read a word you write.',
        trust: [
          { title: 'No accounts', body: 'No sign-up, no email at all.' },
          { title: 'On your device', body: 'Signals stay where they were read.' },
          { title: 'Your own iCloud only', body: 'Sync is opt-in, scoped to your Apple ID.' },
        ],
        links: { privacy: 'Privacy Policy', terms: 'Terms of Use' },
        deviceAlt: 'Hamdam Privacy screen (final screenshot pending)',
      };

const TRUST_ICONS = [
  'M12 3l7 3v5c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z', // no accounts: shield outline (nothing to sign into)
  'M7 4h10a1 1 0 011 1v14a1 1 0 01-1 1H7a1 1 0 01-1-1V5a1 1 0 011-1zM10 18h4', // on your device: phone
  'M7 17a4 4 0 010-8 5 5 0 019.6-1.5A4 4 0 0117 17H7z', // your own iCloud: cloud
];

const privacyHref = lang === 'fa' ? '/fa/privacy' : '/privacy';
const termsHref = lang === 'fa' ? '/fa/terms' : '/terms';
---

<section id="privacy" class="privacy-trust" aria-labelledby="privacy-trust-title">
  <div class="privacy-trust__inner">
    <div class="privacy-trust__content">
      <p id="privacy-trust-title" class="privacy-trust__statement text-balance">{copy.statement}</p>

      <ul class="privacy-trust__row" data-reveal-group>
        {copy.trust.map((item, i) => (
          <li class="privacy-trust__item" data-reveal>
            <svg class="privacy-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={TRUST_ICONS[i]} />
            </svg>
            <span class="privacy-trust__item-title">{item.title}</span>
            <span class="privacy-trust__item-body">{item.body}</span>
          </li>
        ))}
      </ul>

      <nav class="privacy-trust__links" aria-label={copy.links.privacy}>
        <a href={privacyHref}>{copy.links.privacy}</a>
        <a href={termsHref}>{copy.links.terms}</a>
      </nav>
    </div>

    {
      /* DV-01 (device frame) is now real; the orchestrator 06-privacy
         screenshot that belongs inside it is still pending. */
    }
    <div class="privacy-trust__device" role="img" aria-label={copy.deviceAlt}>
      <Image
        src={deviceFrame}
        alt=""
        width={480}
        height={Math.round((480 / deviceFrame.width) * deviceFrame.height)}
        quality={72}
        class="privacy-trust__device-frame"
      />
    </div>
  </div>
</section>

<style>
  .privacy-trust {
    padding-block: var(--spacing-section-mobile);
    padding-inline: 1.5rem;
    background-color: var(--surface-dawn);
    color: var(--hamdam-text);
  }
  @media (min-width: 640px) {
    .privacy-trust {
      padding-block: var(--spacing-section-desktop);
    }
  }

  .privacy-trust__inner {
    max-width: 1200px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: center;
    text-align: center;
  }

  .privacy-trust__content {
    max-width: 60ch;
  }

  .privacy-trust__statement {
    font-family: var(--font-serif);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.3;
  }
  :global([lang='fa']) .privacy-trust__statement {
    font-family: var(--font-farsi);
    font-weight: 500;
  }

  .privacy-trust__row {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .privacy-trust__row {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .privacy-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .privacy-trust__icon {
    width: 28px;
    height: 28px;
    /* --color-ember reads near-invisibly close to this section's own
       --surface-dawn background (Phase 7's constellation had the same
       bug) -- use the body text colour for real contrast instead. */
    color: var(--hamdam-text);
  }

  .privacy-trust__item-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-body);
  }
  :global([lang='fa']) .privacy-trust__item-title {
    font-family: var(--font-farsi);
  }

  .privacy-trust__item-body {
    font-size: var(--text-meta);
    /* No opacity reduction, same reasoning as ContextConstellation's
       node-clause fix: --hamdam-text is only 5.13:1 on --surface-dawn,
       and any opacity reduction drops this small text below 4.5:1. */
  }

  .privacy-trust__links {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
    gap: 2rem;
  }
  .privacy-trust__links a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--hamdam-text);
  }

  .privacy-trust__device {
    position: relative;
    width: min(200px, 50vw);
    aspect-ratio: 1290 / 2796;
    border-radius: var(--radius-device);
    background: linear-gradient(to bottom, var(--surface-dusk), var(--surface-firstlight));
    box-shadow: var(--shadow-rest);
    overflow: hidden;
  }
  .privacy-trust__device-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (min-width: 1024px) {
    .privacy-trust__inner {
      flex-direction: row;
      text-align: start;
      align-items: center;
    }
    .privacy-trust__row {
      text-align: start;
    }
    .privacy-trust__item {
      align-items: flex-start;
    }
    .privacy-trust__links {
      justify-content: flex-start;
    }
    .privacy-trust__device {
      flex-shrink: 0;
      margin-inline-start: 2.5rem;
    }
  }
</style>
