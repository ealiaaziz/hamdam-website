---
interface Props {
  persian: string;
  translation: string;
  poet: string;
  class?: string;
}

const { persian, translation, poet, class: className = '' } = Astro.props;
---

<figure
  data-reveal
  class:list={[
    'flex h-full flex-col rounded-[var(--radius-card)] bg-card p-6 sm:p-8 shadow-card backdrop-blur-sm',
    className,
  ]}
>
  <blockquote lang="fa" dir="rtl" class="grow">
    <p class="font-farsi text-[length:var(--text-verse-fa)] font-medium leading-[1.9] text-start text-indigo whitespace-pre-line [text-wrap:pretty]">
      {persian}
    </p>
  </blockquote>
  <p lang="en" dir="ltr" class="mt-6 font-serif italic leading-[1.7] text-[var(--hamdam-text-soft)]">
    {translation}
  </p>
  <figcaption class="mt-6">
    <cite class="text-sm font-medium not-italic tracking-[0.08em] text-saffron-ink [font-variant:small-caps]">
      {poet}
    </cite>
  </figcaption>
</figure>
