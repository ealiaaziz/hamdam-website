---
import PersianShamseh from './PersianShamseh.astro';

interface Props {
  persian: string;
  translation: string;
  attribution: string;
  class?: string;
}

const { persian, translation, attribution, class: className = '' } = Astro.props;
---

<figure
  data-fade-in
  class:list={[
    'mx-auto max-w-[var(--container-design)] rounded-[var(--radius-card)] bg-card p-8 shadow-card backdrop-blur-sm sm:p-12',
    className,
  ]}
>
  <blockquote>
    <p dir="rtl" class="font-farsi text-start text-2xl leading-[1.9] text-indigo">
      {persian}
    </p>
    <div class="my-6 flex justify-center">
      <PersianShamseh size={24} opacity={0.7} />
    </div>
    <p class="font-serif text-xl italic leading-[1.7] text-indigo/90">
      {translation}
    </p>
  </blockquote>
  <figcaption class="mt-6 text-sm font-medium not-italic text-saffron-ink">
    — {attribution}
  </figcaption>
</figure>
