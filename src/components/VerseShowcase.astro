---
import type { ImageMetadata } from 'astro:assets';
import VerseCard from './VerseCard.astro';
import SceneBackground from './SceneBackground.astro';
import { verses } from '../data/verses';

interface Props {
  lang: 'en' | 'fa';
  intro: string;
  sceneImage?: ImageMetadata;
}

const { lang, intro, sceneImage } = Astro.props;
---

<section class="relative px-6 py-[var(--spacing-section-mobile)] sm:py-[var(--spacing-section-desktop)]">
  {sceneImage && <SceneBackground image={sceneImage} />}
  <div class="relative mx-auto grid max-w-6xl grid-cols-1 gap-8 lg:grid-cols-3" data-reveal-group>
    {verses.map((verse) => (
      <VerseCard
        persian={verse.persian}
        translation={verse.english}
        poet={lang === 'fa' ? verse.poetFa : verse.poetEn}
      />
    ))}
  </div>
  <p
    class:list={[
      'mx-auto mt-12 max-w-md text-center',
      lang === 'fa' ? 'font-farsi text-lg leading-[1.9]' : 'font-serif italic',
      'text-indigo/70',
    ]}
  >
    {intro}
  </p>
</section>
