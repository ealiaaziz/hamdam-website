---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';

interface Props {
  persianName: string;
  transliteration: string;
  description: string;
  lang: 'en' | 'fa';
  portrait: ImageMetadata;
  /** True for the desktop centre card (page spec §4 item 3: "centre card slightly larger"). */
  emphasized?: boolean;
  class?: string;
}

const { persianName, transliteration, description, lang, portrait, emphasized = false, class: className = '' } = Astro.props;

const portraitAlt =
  lang === 'fa'
    ? `پرتره ${persianName} (برداشت هنری)`
    : `Portrait of ${transliteration} (artistic interpretation)`;
---

<div
  data-reveal
  class:list={[
    'poet-card group shrink-0 snap-center',
    emphasized && 'poet-card--emphasized',
    className,
  ]}
>
  {
    /* PT-01 through PT-05: 14-canva-asset-brief.md portrait gallery band
       (§4), cultural approval granted 2026-07-18 (all five as one series
       per 22-dependency-decision.md). Persian name stays live text on its
       own caption plate, never baked into the portrait image. */
  }
  <div class="poet-card__portrait">
    <Image
      src={portrait}
      alt={portraitAlt}
      width={portrait.width}
      height={portrait.height}
      class="poet-card__portrait-img"
    />
    <div class="poet-card__plate">
      <h3 dir="rtl" class="poet-card__name font-farsi">{persianName}</h3>
    </div>
  </div>
  <p class="poet-card__translit">{transliteration}</p>
  <p class="poet-card__description font-serif italic">{description}</p>
</div>

<style>
  .poet-card {
    width: 220px;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-card);
  }
  .poet-card--emphasized {
    width: 248px;
  }
  @media (min-width: 640px) {
    .poet-card {
      width: 240px;
    }
    .poet-card--emphasized {
      width: 272px;
    }
  }

  .poet-card__portrait {
    position: relative;
    aspect-ratio: 2 / 3;
    border-radius: var(--radius-card);
    background: linear-gradient(160deg, var(--surface-dusk), var(--surface-firstlight));
    box-shadow: var(--shadow-rest);
    overflow: hidden;
    transition: box-shadow 150ms var(--ease-cross), transform 150ms var(--ease-cross);
  }
  .poet-card__portrait-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .group:hover .poet-card__portrait,
  .group:focus-within .poet-card__portrait {
    transform: translateY(-4px);
    box-shadow: 0 0 48px var(--glow-warm), var(--shadow-lift);
  }
  @media (prefers-reduced-motion: reduce) {
    .poet-card__portrait {
      transition: none;
    }
    .group:hover .poet-card__portrait,
    .group:focus-within .poet-card__portrait {
      transform: none;
      /* --color-saffron-ink is tuned for cream; the poets band sits on
         --surface-dusk, where it measures 2.60:1 (Phase 11/12 contrast
         audit) -- below the 3:1 non-text minimum. --hamdam-night-gold
         gives 9.52:1 here. */
      box-shadow: 0 0 0 2px var(--hamdam-night-gold), var(--shadow-rest);
    }
  }

  .poet-card__plate {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    background: rgb(20 20 48 / 0.72);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }
  .poet-card__name {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--text-on-night);
  }

  .poet-card__translit {
    margin-top: 0.75rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    /* --color-saffron-ink is darkened specifically for cream backgrounds;
       the poets band sits on --surface-dusk (dark), so this needs the
       night-surface accent pairing instead (design-system.md §1). */
    color: var(--hamdam-night-gold);
  }

  .poet-card__description {
    margin-top: 0.5rem;
    text-align: center;
    font-size: var(--text-body);
    color: var(--text-on-night);
  }
</style>
