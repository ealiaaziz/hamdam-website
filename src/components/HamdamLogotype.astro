---
interface Props {
  lang?: 'en' | 'fa';
  size?: number;
  showMark?: boolean;
  class?: string;
}

const { lang = 'en', size = 24, showMark = true, class: className = '' } = Astro.props;
const wordmark = lang === 'fa' ? 'همدم' : 'Hamdam';
const fontClass = lang === 'fa' ? 'font-farsi' : 'font-serif';
// The real app icon (already used for the PWA manifest at icon-192/512),
// not the abstract shamseh line mark -- the brand identifier in nav/footer
// should be recognisably the same icon someone sees on their home screen.
// Self-contained raster square (its own rounded-corner frame and warm
// gradient), so it reads on both the nav's dark and light states without
// needing a currentColor treatment the way the line mark did.
const markSize = Math.round(size * 0.85);
---

<span class:list={['inline-flex items-center gap-2', className]}>
  {showMark && (
    <img
      src="/icons/icon-192.png"
      width={markSize}
      height={markSize}
      alt=""
      class="rounded-[22%]"
    />
  )}
  {/* 24px (text-2xl) is the only size in use; a literal class keeps the
      wordmark styleable under the no-inline-styles CSP. text-current so
      callers set colour via their own ancestor (body defaults to indigo,
      NavBar sets its own on-night colour); every existing usage inherits
      indigo from <body> so this is a no-op there. */}
  <span class:list={[fontClass, 'font-bold text-current text-2xl']}>
    {wordmark}
  </span>
</span>
