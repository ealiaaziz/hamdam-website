---
import PersianShamseh from './PersianShamseh.astro';

interface Props {
  lang?: 'en' | 'fa';
  size?: number;
  showMark?: boolean;
  class?: string;
}

const { lang = 'en', size = 24, showMark = true, class: className = '' } = Astro.props;
const wordmark = lang === 'fa' ? 'همدم' : 'Hamdam';
const fontClass = lang === 'fa' ? 'font-farsi' : 'font-serif';
---

<span class:list={['inline-flex items-center gap-2', className]}>
  {showMark && <PersianShamseh size={size * 0.7} />}
  <span class:list={[fontClass, 'font-bold text-indigo']} style={{ fontSize: `${size}px` }}>
    {wordmark}
  </span>
</span>
