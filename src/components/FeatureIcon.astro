---
interface Props {
  name: 'siri' | 'widget' | 'watch' | 'health' | 'music' | 'companion' | 'calendar' | 'family';
  label: string;
  lang?: 'en' | 'fa';
}

const { name, label, lang = 'en' } = Astro.props;
---

<div class="flex flex-col items-center gap-3">
  <span class="flex h-14 w-14 items-center justify-center rounded-full bg-cream text-indigo/70 shadow-card">
    {name === 'siri' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="9" x2="4" y2="15" />
          <line x1="9" y1="5" x2="9" y2="19" />
          <line x1="14" y1="2" x2="14" y2="22" />
          <line x1="19" y1="7" x2="19" y2="17" />
        </g>
      </svg>
    )}
    {name === 'widget' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1.5" />
          <rect x="14" y="3" width="7" height="7" rx="1.5" />
          <rect x="3" y="14" width="7" height="7" rx="1.5" />
          <rect x="14" y="14" width="7" height="7" rx="1.5" />
        </g>
      </svg>
    )}
    {name === 'watch' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="7" y="7" width="10" height="10" rx="3" />
          <path d="M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3" />
          <path d="M9 17v3a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-3" />
        </g>
      </svg>
    )}
    {name === 'health' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 20s-7-4.35-9.5-8.5C1 8.5 2.5 5 6 5c2 0 3.2 1.2 4 2.3.8-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 15.65 12 20 12 20z"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linejoin="round"
        />
      </svg>
    )}
    {name === 'music' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="7" cy="18" r="2.5" />
          <circle cx="16" cy="16" r="2.5" />
          <path d="M9.5 18V6l9-2v12" />
        </g>
      </svg>
    )}
    {name === 'companion' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3" />
          <ellipse cx="12" cy="12" rx="10" ry="4.5" transform="rotate(-20 12 12)" />
        </g>
      </svg>
    )}
    {name === 'calendar' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3.5" y="5" width="17" height="16" rx="2" />
          <line x1="3.5" y1="10" x2="20.5" y2="10" />
          <line x1="8" y1="3" x2="8" y2="7" />
          <line x1="16" y1="3" x2="16" y2="7" />
        </g>
      </svg>
    )}
    {name === 'family' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="8.5" cy="8" r="3" />
          <circle cx="16" cy="9" r="2.3" />
          <path d="M3 20c0-3.3 2.5-5.5 5.5-5.5S14 16.7 14 20" />
          <path d="M14.5 20c0-2.4 1.7-4.2 4-4.2s3.5 1.6 3.5 4.2" />
        </g>
      </svg>
    )}
  </span>
  <span
    class:list={[
      'text-xs font-medium text-indigo/60',
      lang === 'fa' ? 'font-farsi' : 'uppercase tracking-wide',
    ]}
  >
    {label}
  </span>
</div>
