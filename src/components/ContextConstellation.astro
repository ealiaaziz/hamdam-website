---
interface Props {
  lang: 'en' | 'fa';
}

const { lang } = Astro.props;

// Exactly the six signal families in the primary message (page spec §5
// item 2), each traceable to Privacy Policy §1: mood/health from §1.1,
// weather from §1.3, calendar from §1.2. Season and time of day are the
// two that need no permission at all (derived from the device's own
// clock/locale, not a protected resource), so they have no numbered
// subsection of their own -- that is the honest reason, not an omission.
// Flagged for Ealia to confirm the wording reads right against the
// shipped policy text before this section is considered final.
const NODES = [
  {
    id: 'mood',
    labelEn: 'Mood',
    labelFa: 'حال و هوا',
    clauseEn: 'Only if you log it. A nudge in tone, not a score.',
    clauseFa: 'فقط اگر خودت ثبت کنی؛ اثرش در لحن است، نه در امتیاز.',
  },
  {
    id: 'weather',
    labelEn: 'Weather',
    labelFa: 'آب‌وهوا',
    clauseEn: "Through Apple's WeatherKit, on your device.",
    clauseFa: 'از طریق WeatherKit اپل، روی همان دستگاه تو.',
  },
  {
    id: 'season',
    labelEn: 'Season',
    labelFa: 'فصل',
    clauseEn: 'Where you are, time of year.',
    clauseFa: 'بر اساس موقعیت و فصل سال.',
  },
  {
    id: 'time',
    labelEn: 'Time of day',
    labelFa: 'ساعت روز',
    clauseEn: 'Morning, midday, evening, night.',
    clauseFa: 'صبح، ظهر، عصر، شب.',
  },
  {
    id: 'calendar',
    labelEn: 'Calendar',
    labelFa: 'تقویم',
    clauseEn: 'Cultural moments only, never event details.',
    clauseFa: 'فقط مناسبت‌های فرهنگی، هرگز جزئیات رویدادها.',
  },
  {
    id: 'health',
    labelEn: 'Health',
    labelFa: 'سلامت',
    clauseEn: 'Only if you choose, only on your device.',
    clauseFa: 'فقط اگر خودت بخواهی، فقط روی همان دستگاه.',
  },
] as const;

const heading = lang === 'fa' ? 'یک تأمل، شکل‌گرفته از روز تو.' : 'One reflection, shaped by your day.';
const privacyLinkLabel = lang === 'fa' ? 'ببین چطور خصوصی می‌ماند' : 'See how it stays private';
const deviceAlt =
  lang === 'fa'
    ? 'پیش‌نمایش صفحه اصلی همدم (تصویر نهایی در دست تهیه)'
    : 'Hamdam Today screen preview (final screenshot pending)';

const NODE_ICONS: Record<(typeof NODES)[number]['id'], string> = {
  mood: 'M12 4a8 8 0 100 16 8 8 0 000-16zM9 10h.01M15 10h.01M8.5 14.5c1 1 2.2 1.5 3.5 1.5s2.5-.5 3.5-1.5',
  weather: 'M7 17a4 4 0 010-8 5 5 0 019.6-1.5A4 4 0 0117 17H7z',
  season: 'M12 3c0 6-6 6-6 12a6 6 0 0012 0c0-6-6-6-6-12z',
  time: 'M12 4a8 8 0 100 16 8 8 0 000-16zm0 4v4l3 2',
  calendar: 'M4 9h16M7 4v3M17 4v3M5 6h14a1 1 0 011 1v12a1 1 0 01-1 1H5a1 1 0 01-1-1V7a1 1 0 011-1z',
  health: 'M4 12h4l2-6 4 12 2-6h4',
};
---

<section class="constellation" aria-labelledby="constellation-title">
  <div class="constellation__inner">
    <h2 id="constellation-title" class="constellation__heading text-balance">{heading}</h2>

    <div class="constellation__diagram">
      <div class="constellation__device" role="img" aria-label={deviceAlt}>
        {import.meta.env.DEV && <span class="constellation__device-label">DV-01 pending</span>}
      </div>

      {
        /* Hairline arcs are presentation only -- the six signals are real
           content in the <ul> below, never encoded in the arc geometry
           (page spec §5 item 11). Dropped entirely on mobile via CSS. */
      }
      <svg class="constellation__arcs" aria-hidden="true" viewBox="0 0 600 400" preserveAspectRatio="none">
        <g fill="none" stroke="var(--color-divider)" stroke-width="1">
          <path d="M300 200 L60 60" /><path d="M300 200 L60 200" /><path d="M300 200 L60 340" />
          <path d="M300 200 L540 60" /><path d="M300 200 L540 200" /><path d="M300 200 L540 340" />
        </g>
      </svg>

      <ul class="constellation__nodes" data-reveal-group>
        {NODES.map((node) => (
          <li class="constellation__node" data-reveal>
            <svg class="constellation__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={NODE_ICONS[node.id]} />
            </svg>
            <span class="constellation__node-label">{lang === 'fa' ? node.labelFa : node.labelEn}</span>
            <span class="constellation__node-clause">{lang === 'fa' ? node.clauseFa : node.clauseEn}</span>
          </li>
        ))}
      </ul>
    </div>

    <a href="#privacy" class="constellation__link">{privacyLinkLabel}</a>
  </div>
</section>

<style>
  .constellation {
    padding-block: var(--spacing-section-mobile);
    padding-inline: 1.5rem;
    background-color: var(--surface-dawn);
    color: var(--hamdam-text);
  }
  @media (min-width: 640px) {
    .constellation {
      padding-block: var(--spacing-section-desktop);
    }
  }

  .constellation__inner {
    max-width: 1200px;
    margin-inline: auto;
    text-align: center;
  }

  .constellation__heading {
    font-family: var(--font-serif);
    font-size: var(--text-h2);
    font-weight: 600;
  }
  :global([lang='fa']) .constellation__heading {
    font-family: var(--font-farsi);
    font-weight: 500;
  }

  .constellation__diagram {
    position: relative;
    margin-top: 3rem;
  }

  .constellation__device {
    width: min(220px, 55vw);
    aspect-ratio: 1290 / 2796;
    margin-inline: auto;
    border-radius: var(--radius-device);
    background: linear-gradient(to bottom, var(--surface-dusk), var(--surface-firstlight));
    box-shadow: var(--shadow-lift);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .constellation__device-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-on-night-muted);
    padding: 0 0.75rem;
    text-align: center;
  }

  .constellation__arcs {
    display: none;
  }

  .constellation__nodes {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 1rem;
    text-align: start;
  }

  .constellation__node {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .constellation__icon {
    width: 24px;
    height: 24px;
    margin-bottom: 0.25rem;
    /* --color-ember reads almost invisibly close to --surface-dawn (this
       section's background) in hue and luminance -- inherit the label's
       own dark text colour instead for real contrast. */
    color: var(--hamdam-text);
  }

  .constellation__node-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-body);
  }
  :global([lang='fa']) .constellation__node-label {
    font-family: var(--font-farsi);
  }

  .constellation__node-clause {
    font-size: var(--text-meta);
    opacity: 0.75;
  }

  .constellation__link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-saffron-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Desktop: real constellation ring, three nodes per side, arcs visible. */
  @media (min-width: 1024px) {
    .constellation__diagram {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 420px;
    }
    .constellation__device {
      width: 220px;
      margin-inline: 0;
    }
    .constellation__arcs {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    /* Arc coordinates are physical SVG geometry, not logical properties,
       so RTL needs an explicit flip to mirror alongside the node
       positions above (which already mirror for free via inset-inline-*). */
    :global([dir='rtl']) .constellation__arcs {
      transform: scaleX(-1);
    }
    .constellation__nodes {
      position: absolute;
      inset: 0;
      display: block;
      pointer-events: none;
    }
    .constellation__node {
      position: absolute;
      width: 200px;
      pointer-events: auto;
    }
    .constellation__node:nth-child(1) { top: 8%; inset-inline-start: 2%; text-align: end; }
    .constellation__node:nth-child(2) { top: 44%; inset-inline-start: 0; text-align: end; }
    .constellation__node:nth-child(3) { top: 80%; inset-inline-start: 2%; text-align: end; }
    .constellation__node:nth-child(4) { top: 8%; inset-inline-end: 2%; text-align: start; }
    .constellation__node:nth-child(5) { top: 44%; inset-inline-end: 0; text-align: start; }
    .constellation__node:nth-child(6) { top: 80%; inset-inline-end: 2%; text-align: start; }
  }
</style>
