---
import PersianShamseh from './PersianShamseh.astro';
import HamdamLogotype from './HamdamLogotype.astro';
---

<footer class="border-t border-saffron/30 px-6 py-20">
  <div class="mx-auto flex max-w-xl flex-col items-center gap-4 text-center">
    <PersianShamseh size={16} opacity={0.7} />
    <HamdamLogotype size={24} showMark={false} />
    <p class="text-sm text-indigo/70">An app by the Hamdam Team</p>
    <nav aria-label="Footer" class="flex items-center gap-3 text-sm text-indigo/70">
      <a href="/privacy" class="hover:text-indigo">Privacy</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/terms" class="hover:text-indigo">Terms</a>
      <span aria-hidden="true">&middot;</span>
      <a href="mailto:developer@hamdam.com.au" class="hover:text-indigo">Contact</a>
    </nav>
    <p class="text-sm text-indigo/70">Made with love in Brisbane.</p>
    <p class="text-xs text-indigo/50">&copy; {new Date().getFullYear()} Hamdam. All rights reserved.</p>
    <p class="text-xs text-indigo/60">
      HAMDAM&trade; is the subject of Australian trade mark application no. 2674427, filed 11
      July 2026.
    </p>
    <p class="text-xs text-indigo/60">
      For support, contact <a href="mailto:developer@hamdam.com.au" class="underline hover:text-indigo">developer@hamdam.com.au</a>.
    </p>
  </div>
</footer>
