---
import { LOCALES, resolveLocaleFromPath, switchLocalePath } from '../lib/locale';

interface Props {
  lang: 'en' | 'fa';
}

const { lang } = Astro.props;
const target = lang === 'fa' ? LOCALES.EN : LOCALES.FA;
const href = switchLocalePath(Astro.url.pathname, target);
// Sanity: the computed target path must resolve to the target locale.
if (resolveLocaleFromPath(href) !== target) {
  throw new Error(`LanguageToggle: ${Astro.url.pathname} -> ${href} does not resolve to ${target}`);
}
const label = lang === 'fa' ? 'English' : 'فارسی';
// aria-label speaks the source locale (the language the visitor is reading now).
const ariaLabel = lang === 'fa' ? 'به انگلیسی' : 'Switch to Farsi';
---

<a
  href={href}
  aria-label={`${ariaLabel} (${label})`}
  class="fixed top-6 end-6 z-40 inline-flex min-h-[44px] items-center rounded-full bg-white/60 px-5 text-sm font-medium text-indigo backdrop-blur transition-colors duration-200 hover:bg-white/90"
>
  {label}
</a>
