---
import { verses } from '../data/verses';
import { MOOD_STOPS } from '../lib/moodDemo';

interface Props {
  lang: 'en' | 'fa';
}

const { lang } = Astro.props;
const initialStop = MOOD_STOPS[2]; // "steady" -- panel opens in a neutral state, not a mood.
const initialVerse = verses.find((v) => v.id === initialStop.verseId)!;

const copy =
  lang === 'fa'
    ? {
        title: 'به همدم بگو دلت چه‌طور است تا با شعری پاسخ دهد.',
        caption: 'اپلیکیشن همدم همین‌گونه کار می‌کند؛ در همدم، تأمل تو از همان‌جا ادامه پیدا می‌کند.',
        link: 'چیزهای بیشتری در اپلیکیشن منتظرت است.',
        sliderLabel: 'دلت امروز چطور است',
      }
    : {
        title: 'Tell Hamdam how your heart feels. It answers with a verse.',
        caption: 'This is how the app works. In Hamdam, your reflection follows.',
        link: 'There is more waiting for you in the app',
        sliderLabel: 'How your heart feels today',
      };
---

<section id="mood-demo" class="mood-demo" aria-labelledby="mood-demo-title">
  <div class="mood-demo__inner">
    <h2 id="mood-demo-title" class="mood-demo__title text-balance">{copy.title}</h2>

    <div class="mood-demo__panel" data-mood-sky={initialStop.sky}>
      <div class="mood-demo__verse" aria-live="polite">
        <p class="mood-demo__verse-fa" lang="fa" dir="rtl">{initialVerse.persian}</p>
        <p class="mood-demo__verse-en">{initialVerse.english}</p>
        <p class="mood-demo__verse-poet">{lang === 'fa' ? initialVerse.poetFa : initialVerse.poetEn}</p>
      </div>
      {
        /* Wordless "reading the moment" beat, added 2026-07-20: a brief pause
           between moving the slider and the verse changing, so the swap
           reads as considered rather than a mechanical lookup. Deliberately
           no caption text (a typing-indicator convention needs none), which
           also means no Farsi copy is required here, consistent with this
           repo's rule that only Ealia authors Persian marketing text. Purely
           decorative: the actual update is still announced via the existing
           aria-live region above once the verse lands, so this is
           aria-hidden and never itself becomes the accessible content. */
      }
      <div class="mood-demo__sensing" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="mood-demo__slider-wrap">
      <input
        id="mood-slider"
        type="range"
        min="0"
        max={MOOD_STOPS.length - 1}
        step="1"
        value="2"
        aria-label={copy.sliderLabel}
        aria-valuetext={lang === 'fa' ? initialStop.labelFa : initialStop.labelEn}
        class="mood-demo__slider"
      />
      <div class="mood-demo__stops" aria-hidden="true">
        {MOOD_STOPS.map((s) => (
          <span>{lang === 'fa' ? s.labelFa : s.labelEn}</span>
        ))}
      </div>
    </div>

    <p class="mood-demo__caption">{copy.caption}</p>
    <a href="#ceremony" class="mood-demo__link">{copy.link}</a>
  </div>
</section>

<style>
  .mood-demo {
    padding-block: var(--spacing-section-mobile);
    padding-inline: 1.5rem;
  }
  @media (min-width: 640px) {
    .mood-demo {
      padding-block: var(--spacing-section-desktop);
    }
  }

  .mood-demo__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .mood-demo__title {
    font-family: var(--font-serif);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-indigo);
  }
  :global([lang='fa']) .mood-demo__title {
    font-family: var(--font-farsi);
    font-size: var(--text-h2);
    font-weight: 500;
    line-height: 1.5;
  }

  .mood-demo__panel {
    position: relative;
    margin-top: 2rem;
    border-radius: var(--radius-panel);
    padding: 2rem 1.5rem;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--mood-sky-color, var(--surface-firstlight));
    color: var(--mood-text-color, var(--text-on-night));
    transition: background-color 400ms var(--ease-cross), color 400ms var(--ease-cross);
  }
  @media (prefers-reduced-motion: reduce) {
    .mood-demo__panel {
      transition: none;
    }
  }

  /* Discrete per-stop sky states (design-system.md §1's named surfaces --
     same five tokens Phase 4's page-level ramp uses, reused here as flat
     fills rather than a continuous arc). */
  .mood-demo__panel[data-mood-sky='night'] { --mood-sky-color: var(--surface-night); --mood-text-color: var(--text-on-night); }
  .mood-demo__panel[data-mood-sky='dusk'] { --mood-sky-color: var(--surface-dusk); --mood-text-color: var(--text-on-night); }
  .mood-demo__panel[data-mood-sky='firstlight'] { --mood-sky-color: var(--surface-firstlight); --mood-text-color: var(--text-on-night); }
  .mood-demo__panel[data-mood-sky='dawn'] { --mood-sky-color: var(--surface-dawn); --mood-text-color: var(--hamdam-text); }
  .mood-demo__panel[data-mood-sky='morning'] { --mood-sky-color: var(--surface-morning); --mood-text-color: var(--hamdam-text); }

  .mood-demo__verse {
    max-width: 44rem;
    opacity: 1;
    transition: opacity 200ms var(--ease-cross);
  }

  .mood-demo__sensing {
    position: absolute;
    inset: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms var(--ease-cross);
  }
  .mood-demo__sensing span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.35;
  }
  .mood-demo__panel--sensing .mood-demo__verse {
    opacity: 0;
  }
  .mood-demo__panel--sensing .mood-demo__sensing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mood-demo__panel--sensing .mood-demo__sensing span {
      animation: mood-sensing-pulse 900ms var(--ease-cross) infinite;
    }
    .mood-demo__sensing span:nth-child(2) { animation-delay: 150ms; }
    .mood-demo__sensing span:nth-child(3) { animation-delay: 300ms; }
  }
  @keyframes mood-sensing-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.25); }
  }
  /* Reduced motion never shows this state at all -- see the script below,
     which skips straight to renderVerse without ever toggling the
     --sensing class, so these rules simply never apply. Kept here only so
     the dots don't render as a hard-edged flash if some future caller adds
     the class directly. */
  @media (prefers-reduced-motion: reduce) {
    .mood-demo__verse,
    .mood-demo__sensing {
      transition: none;
    }
  }
  .mood-demo__verse-fa {
    font-family: var(--font-farsi-verse);
    font-size: var(--text-verse-fa);
    line-height: 1.9;
  }
  .mood-demo__verse-en {
    margin-top: 1rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-verse-en);
    line-height: 1.7;
    /* No opacity reduction: the panel's "light" stop is only 5.13:1
       against --mood-text-color at full strength (Phase 11/12 contrast
       audit); 0.85 measured 4.15:1 there. */
  }
  .mood-demo__verse-poet {
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    /* Same reasoning: 0.7 measured 3.20:1 on the panel's "light" stop. */
  }

  .mood-demo__slider-wrap {
    margin-top: 2rem;
  }

  .mood-demo__slider {
    width: 100%;
    height: 44px;
    accent-color: var(--color-saffron-ink);
    cursor: pointer;
  }

  .mood-demo__stops {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    color: var(--color-indigo);
    opacity: 0.7;
  }
  :global([lang='fa']) .mood-demo__stops {
    font-family: var(--font-farsi);
  }

  .mood-demo__caption {
    margin-top: 2rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-body);
    color: var(--color-indigo);
    opacity: 0.85;
  }
  :global([lang='fa']) .mood-demo__caption {
    font-family: var(--font-farsi);
    font-style: normal;
  }

  .mood-demo__link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-saffron-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>

<script>
  import { verses } from '../data/verses';
  import { MOOD_STOPS, moodStopForIndex, verseForMoodStop, createSettleDebounce } from '../lib/moodDemo';
  import { prefersReducedMotion } from '../lib/cinematic';

  const slider = document.getElementById('mood-slider') as HTMLInputElement | null;
  const panel = document.querySelector<HTMLElement>('.mood-demo__panel');
  const verseFa = document.querySelector<HTMLElement>('.mood-demo__verse-fa');
  const verseEn = document.querySelector<HTMLElement>('.mood-demo__verse-en');
  const versePoet = document.querySelector<HTMLElement>('.mood-demo__verse-poet');
  const lang = document.documentElement.lang === 'fa' ? 'fa' : 'en';

  if (slider && panel && verseFa && verseEn && versePoet) {
    const reducedMotion = prefersReducedMotion();

    const renderVerse = (stop: (typeof MOOD_STOPS)[number]) => {
      const verse = verseForMoodStop(stop, verses);
      if (!verse) return;
      verseFa.textContent = verse.persian;
      verseEn.textContent = verse.english;
      versePoet.textContent = lang === 'fa' ? verse.poetFa : verse.poetEn;
    };

    // Sky crossfades immediately on input (motion spec §4); the verse
    // card waits for a 150ms settle so scrubbing doesn't churn it. Once
    // settled, motion-OK visitors get one extra short "reading" beat
    // (2026-07-20 addition) before the new verse lands, purely cosmetic
    // pacing -- reduced motion skips straight to renderVerse, unchanged
    // from the original behaviour.
    const SENSING_MS = 420;
    const onSettled = (stop) => {
      if (reducedMotion) {
        renderVerse(stop);
        return;
      }
      panel.classList.add('mood-demo__panel--sensing');
      window.setTimeout(() => {
        renderVerse(stop);
        panel.classList.remove('mood-demo__panel--sensing');
      }, SENSING_MS);
    };
    const settleVerse = createSettleDebounce(onSettled, 150);

    slider.addEventListener('input', () => {
      const stop = moodStopForIndex(Number(slider.value));
      panel.setAttribute('data-mood-sky', stop.sky);
      slider.setAttribute('aria-valuetext', lang === 'fa' ? stop.labelFa : stop.labelEn);
      settleVerse(stop, { immediate: reducedMotion });
    });
  }
</script>
